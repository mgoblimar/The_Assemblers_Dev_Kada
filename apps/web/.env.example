VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# AI Provider Configuration
# Options: cerebras (default, highest free limits), gemini, groq
VITE_AI_PROVIDER=cerebras

# Cerebras (recommended — very high free tier limits)
CEREBRAS_API_KEY=your-cerebras-api-key-here
VITE_CEREBRAS_MODEL=llama-3.3-70b

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash-lite
VITE_GEMINI_MODEL=gemini-2.0-flash-lite

# Groq
GROQ_API_KEY=your-groq-api-key-here
VITE_GROQ_MODEL=llama-3.3-70b-versatile
